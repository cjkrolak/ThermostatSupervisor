# SHT31 flask server autostart script
# copy this code to ~/.config/autostart/lxterm-autostart.desktop
# to enable autostart upon reboot.
# Note: for updating dependencies or pulling latest code, run
# sht31_update_and_install.sh manually before restarting.

[Desktop Entry]
Encoding=UTF-8
Name=SHT31 server autostart
Comment=Start a terminal, start DNS service, and launch sht31 server
Exec=/usr/bin/lxterm -hold -e 'cd /home/pi/github/ThermostatSupervisor && sudo /usr/local/bin/noip2 && sudo /usr/local/bin/noip2 -S && python -m src.sht31_flask_server'
Terminal=true
X-KeepTerminal=true